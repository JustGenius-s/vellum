{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Vellum desktop permissions for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:write-files",
    "opener:allow-open-url",
    "opener:allow-default-urls",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*" },
        { "url": "http://localhost:*" },
        { "url": "http://127.0.0.1:*" }
      ]
    }
  ]
}
